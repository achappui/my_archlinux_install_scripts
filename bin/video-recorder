#!/usr/bin/env bash

cleanup() {
    tput cnorm
    stty echoctl
    echo -e
    # stop wl-screenrec si encore actif
    [ -n "$REC_PID" ] && kill "$REC_PID" 2>/dev/null
    exit
}

trap cleanup SIGINT SIGTERM

OUTPUT_DIR="/home/${USER}/Videos"
mkdir -p "${OUTPUT_DIR}"

# Demande du nom de fichier
printf "Enter filename: "
read NAME
if [ -z "$NAME" ]; then
    NAME="screen_$(date +%Y-%m-%d_%H-%M-%S)"
fi

FILENAME="${NAME}.mp4"
COUNTER=1
while [ -e "${OUTPUT_DIR}/${FILENAME}" ]; do
    FILENAME="${NAME}_${COUNTER}.mp4"
    COUNTER=$((COUNTER + 1))
done

# Détecte le moniteur actif sous Sway
MONITOR=$(swaymsg -t get_outputs | jq -r '.[] | select(.focused==true) | .name')

printf "Recording monitor: $MONITOR\n"
printf "Recording to: ${OUTPUT_DIR}/${FILENAME}\n"
printf "Press Ctrl+C to stop\n"

START_TIME=$(date +%s)

# Lance wl-screenrec en background avec audio et GPU
wl-screenrec -o "$MONITOR" -a "@DEFAULT_AUDIO_SOURCE@" -c h264_vaapi -r 60 -f "${OUTPUT_DIR}/${FILENAME}" >/dev/null 2>&1 &
REC_PID=$!

# Masque le curseur et cache les touches
stty -echoctl
tput civis

# Affiche le timer
while kill -0 "$REC_PID" 2>/dev/null; do
    NOW=$(date +%s)
    ELAPSED=$((NOW - START_TIME))
    MINS=$((ELAPSED / 60))
    SECS=$((ELAPSED % 60))
    printf "\r\033[KRecording... %02d:%02d" "$MINS" "$SECS"
    sleep 1
done

tput cnorm
cleanup