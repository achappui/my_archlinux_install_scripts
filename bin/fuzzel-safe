#!/usr/bin/env bash

sel=$(printf '%b' \
"Firefox\0icon\x1ffirefox\n" \
"Foot\0icon\x1ffoot\n" \
"HTop\0icon\x1fhtop\n" \
"GoogleChrome\0icon\x1fgoogle-chrome\n" \
"Brave\0icon\x1fbrave-desktop\n" \
"AzPainter\0icon\x1fazpainter\n" \
"Mousepad\0icon\x1forg.xfce.mousepad\n" \
"lf\0icon\x1futilities-terminal\n" \
"audio-recorder\0icon\x1faudio-input-microphone\n" \
"video-recorder\0icon\x1fcamera-video\n" \
"pavucontrol\0icon\x1fmultimedia-volume-control\n" \
"WiFi\0icon\x1fnetwork-wireless\n" \
"Reboot\0icon\x1fsystem-reboot\n" \
"Poweroff\0icon\x1fsystem-shutdown\n" \
"Sleep\0icon\x1fsystem-suspend" | fuzzel --dmenu --prompt="  ")

confirm_action() {
    confirm=$(printf "No\nYes" | fuzzel --dmenu --prompt="$1" --width=20)
    [[ "$confirm" == "Yes" ]]
}

connect_wifi() {

    if ! systemctl is-active --quiet iwd; then
      printf '%b' "Activate" | fuzzel --dmenu --prompt="Wifi Options " && systemctl enable --now iwd
    fi

    interface=$(iwctl device list | grep -m1 "station" | awk '{print $2}')
    
    chosen_ssid=$(
      printf "Desactivate\n%s\n" "$(
        iwctl station "$interface" get-networks |
        sed -E 's/\x1b\[[0-9;]*m//g' |
        awk 'NR>4 && NF {print ($1==">")?$2:$1}'
      )" | fuzzel --dmenu --prompt="Select WiFi: "
    )

    if [ ${chosen_ssid} = "Desactivate" ]; then
      systemctl disable --now iwd
      return
    fi

    pass=$(fuzzel --dmenu --password="*" --prompt="Password for ${chosen_ssid}: ")
    if [ -z "$pass" ]; then
        return
    fi
    
    iwctl station "${interface}" connect "${chosen_ssid}" --passphrase "${pass}"
    
    success=1
    prompt="Password for ${chosen_ssid}: "
    while [ $success -ne 0 ]; do
        pass=$(fuzzel --dmenu --password="*" --prompt="${prompt}")
        [ -z "$pass" ] && break
        if iwctl station "$interface" connect "$chosen_ssid" --passphrase "$pass"; then
            success=0
        else
            success=1
            prompt="Connection failed try again: "
        fi
    done


}

case "$sel" in
  Firefox*) firefox ;;
  Foot*) foot ;;
  HTop*) foot htop ;;
  GoogleChrome*) google-chrome-stable ;;
  Brave*) brave ;;
  AzPainter*) azpainter ;;
  Mousepad*) mousepad ;;
  lf*) foot lf ;;
  audio-recorder*) foot audio-recorder ;;
  video-recorder*) foot grs-ui ;;
  pavucontrol*) pavucontrol ;;
  Reboot*)   confirm_action "Confirm Reboot? " && systemctl reboot ;;
  Poweroff*) confirm_action "Confirm Poweroff? " && systemctl poweroff ;;
  Sleep*)    confirm_action "Confirm Sleep? " && systemctl suspend ;;
  Wifi*) connect_wifi ;;
esac
