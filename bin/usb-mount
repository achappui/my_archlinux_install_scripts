#!/usr/bin/env bash
DEVNAME="$1"
ACTION="$2"

PART=$(basename ${DEVNAME})
MOUNT_BASE="/media"
BASE_SAVER="/run/disk-automount/${PART}_base_usb_mount"

mkdir -p "/run/disk-automount"

if [ "$ACTION" = "add" ]; then
    LABEL=$(lsblk -no LABEL "${DEVNAME}" | tr -d ' ')
    [ -z "$LABEL" ] && LABEL=$(basename "${DEVNAME}")
    MOUNT_POINT="$MOUNT_BASE/$LABEL"
    mkdir -p "$MOUNT_POINT"
    mkdir -p ".${MOUNT_POINT}"
    echo "$(lsblk -no PKNAME $DEVNAME)" > "${BASE_SAVER}"
    if ! findmnt -n -S "$DEVNAME" > /dev/null; then
        mount "$DEVNAME" "$MOUNT_POINT"
    fi
elif [ "$ACTION" = "remove" ]; then
    MOUNT_POINT=$(grep "$(cat ${BASE_SAVER})" /proc/mounts | awk '{print $2}')
    if [ -n "${MOUNT_POINT}" ]; then
        umount -l ${MOUNT_POINT}
        rmdir ${MOUNT_POINT}
    fi
    rm ${BASE_SAVER}
    find "$MOUNT_BASE" -mindepth 1 -maxdepth 1 -type d -empty -delete
fi
